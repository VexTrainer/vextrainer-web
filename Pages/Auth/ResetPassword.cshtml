@page
@model VexTrainerWeb.Pages.Auth.ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password";
    Layout = "_Layout";
}

<div class="form-container">
    @if (Model.IsTokenValid)
    {
        <h2>Reset Your Password</h2>
        <p class="text-muted mb-20">Enter your new password below.</p>
        
        <form method="post">
            <input type="hidden" name="Token" value="@Model.Token" />
            
            <!-- New Password Field -->
            <div class="form-group floating-label">
                <input type="password" 
                       id="newPassword" 
                       name="NewPassword"
                       asp-for="NewPassword"
                       minlength="8" 
                       required
                       autocomplete="new-password"
                       placeholder=" " />
                <label for="newPassword">New Password</label>
                <button type="button" class="toggle-password" onclick="togglePassword('newPassword', 'eyeIcon1')">
                    <span id="eyeIcon1">👁️</span>
                </button>
                <small class="help-text">Must be 8+ characters with uppercase, lowercase, number, and special character</small>
                <span class="error-message" asp-validation-for="NewPassword"></span>
            </div>

            <!-- Confirm Password Field -->
            <div class="form-group floating-label">
                <input type="password" 
                       id="confirmPassword" 
                       name="ConfirmPassword"
                       asp-for="ConfirmPassword"
                       minlength="8" 
                       required
                       autocomplete="new-password"
                       placeholder=" " />
                <label for="confirmPassword">Confirm New Password</label>
                <button type="button" class="toggle-password" onclick="togglePassword('confirmPassword', 'eyeIcon2')">
                    <span id="eyeIcon2">👁️</span>
                </button>
                <span class="error-message" asp-validation-for="ConfirmPassword"></span>
            </div>

            <!-- Submit Button -->
            <button type="submit" class="btn btn-primary btn-block">Reset Password</button>
            
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-error mt-20">
                    @Model.ErrorMessage
                </div>
            }
        </form>
    }
    else
    {
        <div class="text-center">
            <div style="font-size: 64px; margin-bottom: 20px;">❌</div>
            <h2>Invalid or Expired Link</h2>
            <p class="text-muted mt-20">@Model.ErrorMessage</p>
            <div class="mt-30">
                <a href="/Auth/SignIn" class="btn btn-secondary btn-block">Go to Sign In</a>
                <p class="text-center mt-20">
                    <a href="/Auth/SignIn" onclick="VexTrainer.SignIn.handleForgotPassword(); return false;">
                        Request New Reset Link
                    </a>
                </p>
            </div>
        </div>
    }
</div>
