@page
@model VexTrainerWeb.Pages.Auth.SignInModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "_Layout";
}

<div class="form-container">
    <h2>Sign In to VexTrainer</h2>
    
    <form id="signinForm" method="post">
        <!-- Email Field (Always Visible) -->
        <div class="form-group floating-label">
            <input type="email" 
                   id="email" 
                   name="Email" 
                   asp-for="Email"
                   required 
                   autocomplete="email"
                   placeholder=" " />
            <label for="email">Email</label>
            <span class="error-message" id="emailError"></span>
        </div>
        
        <!-- Password Field (Hidden Initially) -->
        <div class="form-group floating-label" id="passwordGroup" style="display: none;">
            <input type="password" 
                   id="password" 
                   name="Password"
                   asp-for="Password"
                   minlength="8" 
                   autocomplete="current-password"
                   placeholder=" " />
            <label for="password">Password</label>
            <button type="button" class="toggle-password" onclick="togglePassword('password', 'eyeIcon')">
                <span id="eyeIcon">👁️</span>
            </button>
            <span class="error-message" id="passwordError"></span>
        </div>
        
        <!-- Buttons Row (Initial State) -->
        <div class="button-row" id="buttonRow">
            <button type="button" class="btn btn-primary" onclick="VexTrainer.SignIn.handleSignIn()">Sign In</button>
            <button type="button" class="btn btn-primary" onclick="VexTrainer.SignIn.handleForgotPassword()">Forgot Password</button>
        </div>
        
        <!-- Submit Row (Hidden Initially) -->
        <div id="submitRow" style="display: none;">
            <button type="submit" class="btn btn-primary btn-block">Sign In</button>
            <button type="button" class="btn btn-link" onclick="VexTrainer.SignIn.resetForm()">Cancel</button>
        </div>
        
        <!-- Response Message Area -->
        <div id="responseMessage" class="message" style="display: none;"></div>
        
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-error">
                @Model.ErrorMessage
            </div>
        }
        
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                @TempData["SuccessMessage"]
            </div>
        }
    </form>
    
    <!-- Sign Up Button (replaced text link) -->
    <div class="text-center mt-30">
        <button type="button" class="btn btn-secondary btn-block" onclick="VexTrainer.SignIn.handleSignUp()">
            Don't have an account? Sign up free
        </button>
    </div>
</div>

@section Scripts {
<script>
// Initialize SignIn page functionality
VexTrainer.SignIn.init();
</script>
}
