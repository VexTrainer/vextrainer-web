@inject IConfiguration Configuration

@{
    var iosUrl = Configuration["iOS:AppStoreUrl"] ?? "#";
    var androidUrl = Configuration["Android:PlayStoreUrl"] ?? "#";
}

<footer class="site-footer">
    <div class="footer-container">
        <div class="footer-links">
            <a href="/About" class="footer-link">About</a>
            <span class="footer-separator">|</span>
            <a href="/Contact" class="footer-link">Contact Us</a>
            <span class="footer-separator">|</span>
            <a href="/PrivacyPolicy" class="footer-link">Privacy Policy</a>
            <span class="footer-separator">|</span>
            <a href="/Donate" class="footer-link">Donate</a>
        </div>
        
        <div class="footer-apps">
            <span class="footer-apps-label">Download Mobile App:</span>
            <a href="@iosUrl" target="_blank" class="app-badge" title="Download on App Store">
                <svg class="app-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09l.01-.01zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
                </svg>
                iOS
            </a>
            <a href="@androidUrl" target="_blank" class="app-badge" title="Get it on Google Play">
                <svg class="app-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M3.609 1.814L13.792 12 3.609 22.186a.996.996 0 0 1-.103-.112l-.007-.008L3.5 22.07V1.93l-.001-.004.007-.008a.996.996 0 0 1 .103-.112zM13.792 12L3.609 1.814 3.5 1.93V22.07l.109-.116L13.792 12zm.697.697l2.869 2.869-13.147 7.37 10.278-10.239zm10.239-1.394L13.792 12l2.869-2.869 10.239 5.738-2.172 1.219z"/>
                </svg>
                Android
            </a>
        </div>
        
        <div class="footer-copyright">
            <p>&copy; @DateTime.Now.Year VexTrainer. Built for VEX Robotics teams.</p>
        </div>
    </div>
</footer>
