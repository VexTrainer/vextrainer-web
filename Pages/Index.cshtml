@page
@model VexTrainerWeb.Pages.IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="container">
    <div class="dashboard-header">
        <div style="font-size: 64px; margin-bottom: 20px;">🤖</div>
        <h1>VexTrainer</h1>
        <p class="text-muted" style="font-size: 20px;">Learn PROS Programming for VEX Robotics</p>
        <div style="margin-top: 30px; display: flex; gap: 15px; justify-content: center;">
            <a href="/Auth/Register" class="btn btn-primary" style="font-size: 18px; padding: 15px 40px;">Get Started Free</a>
            <a href="/Auth/SignIn" class="btn btn-secondary" style="font-size: 18px; padding: 15px 40px;">Sign In</a>
        </div>
    </div>

    <div class="card-grid" style="margin-top: 60px;">
        <div class="module-card">
            <div class="module-icon">📚</div>
            <div class="module-title">PROS Fundamentals</div>
            <div class="module-description">Learn the basics of PROS programming</div>
        </div>
        <div class="module-card">
            <div class="module-icon">⚙️</div>
            <div class="module-title">Hardware & Sensors</div>
            <div class="module-description">Master motor control and sensor integration</div>
        </div>
        <div class="module-card">
            <div class="module-icon">🤖</div>
            <div class="module-title">Autonomous Programming</div>
            <div class="module-description">Build powerful autonomous routines</div>
        </div>
    </div>

    <div style="text-align: center; margin: 80px 0 40px;">
        <h2 style="margin-bottom: 20px;">Get the Full Experience</h2>
        <p class="text-muted" style="font-size: 18px;">Download our mobile app for interactive quizzes and progress tracking!</p>
        <div style="margin-top: 30px; display: flex; gap: 20px; justify-content: center;">
            <a href="#" class="app-badge" style="padding: 15px 30px; font-size: 18px;">
                🍎 Download on App Store
            </a>
            <a href="#" class="app-badge" style="padding: 15px 30px; font-size: 18px;">
                🤖 Get it on Google Play
            </a>
        </div>
    </div>
</div>
