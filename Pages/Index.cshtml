@page
@model VexTrainerWeb.Pages.IndexModel
@{
    ViewData["Title"] = "Home";
    Layout = "_Layout";
}

@section Styles {
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<style>
/* ── Reset & base ─────────────────────────────────────────── */
.home-page { font-family: 'Inter', system-ui, sans-serif; }
.home-page * { box-sizing: border-box; }

/* ── Hero ────────────────────────────────────────────────── */
.hero {
    min-height: 92vh;
    background: linear-gradient(135deg, #0a0a1a 0%, #0d1b3e 40%, #1a0a2e 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 3rem 1.5rem 2rem;
    position: relative;
    overflow: hidden;
}
/* star particles */
.hero::before {
    content: '';
    position: absolute; inset: 0;
    background-image:
        radial-gradient(1px 1px at 20% 30%, rgba(255,255,255,0.6) 0%, transparent 100%),
        radial-gradient(1px 1px at 70% 15%, rgba(255,255,255,0.5) 0%, transparent 100%),
        radial-gradient(1px 1px at 45% 60%, rgba(255,255,255,0.4) 0%, transparent 100%),
        radial-gradient(1.5px 1.5px at 85% 45%, rgba(255,255,255,0.5) 0%, transparent 100%),
        radial-gradient(1px 1px at 10% 80%, rgba(255,255,255,0.3) 0%, transparent 100%),
        radial-gradient(1.5px 1.5px at 60% 85%, rgba(255,255,255,0.4) 0%, transparent 100%),
        radial-gradient(1px 1px at 30% 50%, rgba(255,255,255,0.3) 0%, transparent 100%);
    pointer-events: none;
}
/* glow orbs */
.hero::after {
    content: '';
    position: absolute;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(99,102,241,0.15) 0%, transparent 70%);
    top: -100px; left: 50%; transform: translateX(-50%);
    pointer-events: none;
}

.hero-logo {
    width: 80px; height: 80px;
    margin-bottom: 1.5rem;
    filter: drop-shadow(0 0 24px rgba(99,102,241,0.8));
    animation: float 3s ease-in-out infinite;
}
@@keyframes float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-8px); }
}

.hero-tag {
    display: inline-block;
    background: rgba(99,102,241,0.15);
    border: 1px solid rgba(99,102,241,0.4);
    color: #a5b4fc;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    padding: 4px 14px;
    border-radius: 999px;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
}

.hero h1 {
    font-size: clamp(2rem, 6vw, 3.8rem);
    font-weight: 900;
    line-height: 1.1;
    margin: 0 0 1.25rem;
    background: linear-gradient(135deg, #e0e7ff 0%, #a5b4fc 40%, #f472b6 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.hero-sub {
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    color: #94a3b8;
    max-width: 560px;
    margin: 0 auto 2rem;
    line-height: 1.65;
}

.hero-cta {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
}

.btn-glow {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 14px 32px;
    border-radius: 12px;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    transition: all 0.2s;
    cursor: pointer;
    border: none;
}
.btn-glow-primary {
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: #fff;
    box-shadow: 0 0 24px rgba(99,102,241,0.5);
}
.btn-glow-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 36px rgba(99,102,241,0.7);
    color: #fff;
}
.btn-glow-ghost {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.15);
    color: #cbd5e1;
}
.btn-glow-ghost:hover {
    background: rgba(255,255,255,0.1);
    border-color: rgba(255,255,255,0.3);
    transform: translateY(-2px);
    color: #fff;
}

/* trust pills */
.trust-pills {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
}
.trust-pill {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    color: #94a3b8;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 5px 12px;
    border-radius: 999px;
}

/* ── Stats strip ──────────────────────────────────────────── */
.stats-strip {
    background: #f8fafc;
    padding: 3rem 1.5rem;
    border-bottom: 1px solid #e2e8f0;
}
.stats-grid {
    max-width: 800px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 2rem;
    text-align: center;
}
.stat-item { }
.stat-number {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    display: block;
}
.stat-label {
    font-size: 0.82rem;
    font-weight: 600;
    color: #64748b;
    margin-top: 6px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

/* ── Problem statement ────────────────────────────────────── */
.problem-section {
    padding: 4rem 1.5rem;
    max-width: 680px;
    margin: 0 auto;
    text-align: center;
}
.problem-section h2 {
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 1rem;
    line-height: 1.25;
}
.problem-section p {
    font-size: 1.05rem;
    color: #475569;
    line-height: 1.7;
}
.highlight {
    color: #6366f1;
    font-weight: 700;
}

/* ── Feature bento grid ───────────────────────────────────── */
.features-section {
    padding: 1rem 1.5rem 4rem;
    max-width: 960px;
    margin: 0 auto;
}
.bento-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 16px;
}
.bento-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 20px;
    padding: 1.75rem;
    transition: all 0.25s;
    position: relative;
    overflow: hidden;
}
.bento-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, #6366f1, #8b5cf6, #f472b6);
    border-radius: 20px 20px 0 0;
}
.bento-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(99,102,241,0.12);
    border-color: #c7d2fe;
}
.bento-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
    display: block;
}
.bento-card h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: #0f172a;
    margin: 0 0 0.5rem;
}
.bento-card p {
    font-size: 0.9rem;
    color: #64748b;
    line-height: 1.6;
    margin: 0;
}

/* ── Web vs App ───────────────────────────────────────────── */
.compare-section {
    background: linear-gradient(135deg, #f0f4ff, #fdf4ff);
    padding: 4rem 1.5rem;
}
.compare-inner {
    max-width: 800px;
    margin: 0 auto;
}
.compare-inner h2 {
    text-align: center;
    font-size: clamp(1.4rem, 4vw, 2rem);
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 2rem;
}
.compare-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
}
@@media (max-width: 520px) { .compare-grid { grid-template-columns: 1fr; } }
.compare-card {
    background: #fff;
    border-radius: 20px;
    padding: 1.75rem;
    border: 1px solid #e2e8f0;
}
.compare-card.app-card {
    border: 2px solid #6366f1;
    box-shadow: 0 0 24px rgba(99,102,241,0.1);
}
.compare-card-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 1.25rem;
}
.compare-card-header span:first-child { font-size: 1.5rem; }
.compare-card-header strong {
    font-size: 1rem;
    font-weight: 700;
    color: #0f172a;
}
.compare-badge {
    margin-left: auto;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 999px;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: #fff;
}
.compare-list { list-style: none; padding: 0; margin: 0 0 1.25rem; }
.compare-list li {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-size: 0.9rem;
    color: #374151;
    padding: 5px 0;
    border-bottom: 1px solid #f1f5f9;
}
.compare-list li:last-child { border: none; }
.check { color: #22c55e; font-weight: 700; flex-shrink: 0; }
.app-buttons {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
}
.app-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 10px 14px;
    background: #0f172a;
    color: #fff;
    border-radius: 10px;
    text-decoration: none;
    font-size: 0.82rem;
    font-weight: 600;
    transition: all 0.2s;
    min-width: 100px;
}
.app-btn:hover { background: #1e293b; color: #fff; transform: translateY(-1px); }

/* ── Donation section ─────────────────────────────────────── */
.donation-section {
    padding: 4rem 1.5rem;
    max-width: 680px;
    margin: 0 auto;
    text-align: center;
}
.donation-card {
    background: linear-gradient(135deg, #fff7ed, #fef3c7);
    border: 1px solid #fed7aa;
    border-radius: 24px;
    padding: 2.5rem 2rem;
}
.donation-card .donation-icon { font-size: 2.5rem; margin-bottom: 1rem; display: block; }
.donation-card h2 {
    font-size: 1.4rem;
    font-weight: 800;
    color: #92400e;
    margin: 0 0 0.75rem;
}
.donation-card .stat-highlight {
    font-size: 2rem;
    font-weight: 900;
    color: #b45309;
    display: block;
    margin: 0.5rem 0;
}
.donation-card p {
    font-size: 0.95rem;
    color: #78350f;
    line-height: 1.7;
    margin: 0 0 0.75rem;
}
.donation-card .donation-note {
    font-size: 0.8rem;
    color: #92400e;
    opacity: 0.8;
    margin: 0.75rem 0 0;
}
.btn-donate {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: linear-gradient(135deg, #d97706, #b45309);
    color: #fff;
    padding: 12px 28px;
    border-radius: 12px;
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    transition: all 0.2s;
    margin-top: 1.25rem;
    box-shadow: 0 4px 16px rgba(180,83,9,0.3);
}
.btn-donate:hover { transform: translateY(-2px); color: #fff; box-shadow: 0 6px 24px rgba(180,83,9,0.4); }

/* ── Final CTA ────────────────────────────────────────────── */
.final-cta {
    background: linear-gradient(135deg, #0a0a1a 0%, #0d1b3e 40%, #1a0a2e 100%);
    padding: 5rem 1.5rem;
    text-align: center;
}
.final-cta h2 {
    font-size: clamp(1.6rem, 5vw, 2.8rem);
    font-weight: 900;
    background: linear-gradient(135deg, #e0e7ff 0%, #a5b4fc 50%, #f472b6 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin: 0 0 0.75rem;
}
.final-cta p { color: #94a3b8; margin: 0 0 2rem; font-size: 1rem; }

/* ── Responsive ───────────────────────────────────────────── */
@@media (max-width: 600px) {
    .hero { min-height: 80vh; }
    .hero h1 { font-size: 2rem; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
    .bento-grid { grid-template-columns: 1fr; }
}

/* ── Bento header: icon + title on same line ─────────────────────────── */
.bento-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 0.85rem;
}
.bento-header .bento-icon {
    font-size: 1.75rem;
    line-height: 1;
    flex-shrink: 0;
    margin-bottom: 0;
}
.bento-header h3 {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 700;
}

/* ── Stats strip: dark navy ──────────────────────────────────────────── */
.stats-strip {
    background: linear-gradient(135deg, #020617 0%, #0f172a 100%) !important;
    border-bottom: none !important;
}
.stats-strip .stat-label { color: #94a3b8 !important; }

/* ── Bento cards: individual gradient backgrounds ────────────────────── */
.bento-grid .bento-card {
    border-color: transparent;
}
.bento-grid .bento-card::before { display: none; }  /* remove rainbow stripe */

.bento-grid .bento-card:nth-child(1) {
    background: linear-gradient(135deg, #312e81 0%, #4f46e5 100%);
}
.bento-grid .bento-card:nth-child(2) {
    background: linear-gradient(135deg, #0c4a6e 0%, #0891b2 100%);
}
.bento-grid .bento-card:nth-child(3) {
    background: linear-gradient(135deg, #881337 0%, #e11d48 100%);
}
.bento-grid .bento-card h3 { color: #fff; }
.bento-grid .bento-card p  { color: rgba(255,255,255,0.88); }

.bento-grid .bento-card:nth-child(1):hover {
    box-shadow: 0 16px 48px rgba(79,70,229,0.45);
    border-color: rgba(165,180,252,0.3);
}
.bento-grid .bento-card:nth-child(2):hover {
    box-shadow: 0 16px 48px rgba(8,145,178,0.45);
    border-color: rgba(103,232,249,0.3);
}
.bento-grid .bento-card:nth-child(3):hover {
    box-shadow: 0 16px 48px rgba(225,29,72,0.45);
    border-color: rgba(253,164,175,0.3);
}

/* ── Web vs App section: dark slate with glassmorphism cards ─────────── */
.compare-section {
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%) !important;
}
.compare-inner h2 { color: #f1f5f9 !important; }
.compare-card {
    background: rgba(255,255,255,0.05) !important;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.1) !important;
}
.compare-card.app-card {
    background: rgba(99,102,241,0.12) !important;
    border: 2px solid #6366f1 !important;
}
.compare-card-header strong { color: #f1f5f9 !important; }
.compare-list li {
    color: #cbd5e1 !important;
    border-bottom-color: rgba(255,255,255,0.06) !important;
}
.compare-badge { background: linear-gradient(135deg, #6366f1, #8b5cf6) !important; }
</style>
}

<div class="home-page">

  @* ═══ HERO ════════════════════════════════════════════ *@
  <section class="hero">
    <img src="~/images/logo_vextrainer.png" alt="VexTrainer" class="hero-logo" />
    <div class="hero-tag">Built for VEX Robotics Teams</div>
    <h1>Your robot's code.<br/>Finally makes sense.</h1>
    <p class="hero-sub">
      Most teams lose points in skills and autonomous. Not because of their robot.
Because the <strong style="color:#a5b4fc">code isn't there yet</strong>.
      VexTrainer helps you, for free.
    </p>
    <div class="hero-cta">
      <a href="/Auth/Register" class="btn-glow btn-glow-primary">
        🚀 Start Learning Free
      </a>
      <a href="/Auth/SignIn" class="btn-glow btn-glow-ghost">
        Sign In
      </a>
    </div>
    <div class="trust-pills">
      <span class="trust-pill">✅ 100% Free</span>
      <span class="trust-pill">🚫 No Ads</span>
      <span class="trust-pill">🔒 No Data Sold</span>
      <span class="trust-pill">📱 iOS &amp; Android</span>
      <span class="trust-pill">🏆 Competition-Focused</span>
    </div>
  </section>

  @* ═══ STATS ════════════════════════════════════════════ *@
  <section class="stats-strip">
    <div class="stats-grid">
      <div class="stat-item">
        <span class="stat-number" data-target="@Model.Stats.TotalLessons">0</span>
        <span class="stat-label">Lessons</span>
      </div>
      <div class="stat-item">
        <span class="stat-number" data-target="@Model.Stats.TotalTopics">0</span>
        <span class="stat-label">Topics</span>
      </div>
      <div class="stat-item">
        <span class="stat-number" data-target="@Model.Stats.Students">0</span>
        <span class="stat-label">Students</span>
      </div>
      <div class="stat-item">
        <span class="stat-number" data-target="@Model.Stats.TopicsRead">0</span>
        <span class="stat-label">Community Reads</span>
      </div>
    </div>
  </section>

  @* ═══ PROBLEM ══════════════════════════════════════════ *@
  <section class="problem-section">
    <h2>Skills runs shouldn't be a mystery.</h2>
    <p>
      A lot of VEX teams put in the hardware effort but struggle when it comes to
      <span class="highlight">autonomous routines</span> and
      <span class="highlight">skills programming</span>.
      VexTrainer teaches PROS/C++ from zero, structured the way competition
      actually works, not the way a textbook does.
    </p>
  </section>

  @* ═══ FEATURES ═════════════════════════════════════════ *@
  <section class="features-section">
    <div class="bento-grid">
      <div class="bento-card">
        <div class="bento-header">
          <span class="bento-icon">📚</span>
          <h3>Structured Curriculum</h3>
        </div>
        <p>
          @Model.Stats.TotalLessons lessons across @Model.Stats.TotalTopics topics,
          built around what actually matters in competition: motors, sensors,
          autonomous, PID, and beyond.
        </p>
      </div>
      <div class="bento-card">
        <div class="bento-header">
          <span class="bento-icon">🎯</span>
          <h3>Quizzes After Every Lesson</h3>
        </div>
        <p>
          Test your understanding before moving on. Instant feedback tells you
          exactly what you got right and why you got it wrong.
          Available on the mobile app.
        </p>
      </div>
      <div class="bento-card">
        <div class="bento-header">
          <span class="bento-icon">🗺️</span>
          <h3>Zero to Competition-Ready</h3>
        </div>
        <p>
          C++ and the math and physics you need, through sensors, PID control,
          odometry, pure pursuit, and Bezier paths. Covers OkapiLib, EZ-Template,
          and LemLib. From "what's a VEX brain?" to a skills run that ranks.
        </p>
      </div>
    </div>
  </section>

  @* ═══ WEB vs APP ════════════════════════════════════════ *@
  <section class="compare-section">
    <div class="compare-inner">
      <h2>Learn anywhere that works for you</h2>
      <div class="compare-grid">
        <div class="compare-card">
          <div class="compare-card-header">
            <span>🌐</span>
            <strong>Web Browser</strong>
          </div>
          <ul class="compare-list">
            <li><span class="check">✓</span> All @Model.Stats.TotalTopics topics</li>
            <li><span class="check">✓</span> Progress tracking</li>
            <li><span class="check">✓</span> Works on any device</li>
            <li><span class="check">✓</span> No install needed</li>
            <li><span style="color:#ef4444;font-weight:700;">✗</span> No quizzes</li>
          </ul>
        </div>
        <div class="compare-card app-card">
          <div class="compare-card-header">
            <span>📱</span>
            <strong>Mobile App</strong>
            <span class="compare-badge">Recommended</span>
          </div>
          <ul class="compare-list">
            <li><span class="check">✓</span> All @Model.Stats.TotalTopics topics</li>
            <li><span class="check">✓</span> Progress tracking</li>
            <li><span class="check">✓</span> Quizzes &amp; instant feedback</li>
            <li><span class="check">✓</span> Learn in one season</li>
          </ul>
          <div class="app-buttons">
            <a href="#" class="app-btn">🍎 App Store</a>
            <a href="#" class="app-btn">🤖 Google Play</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  @* ═══ DONATION ══════════════════════════════════════════ *@
  <section class="donation-section">
    <div class="donation-card">
      <span class="donation-icon">🌾</span>
      <h2>If this helped your team, pay it forward.</h2>
      <span class="stat-highlight">48 farmers</span>
      <p>
        take their own lives every day in India. Not from despair, but from
        debt they can't escape. VexTrainer is free because education should be.
        But if it helped you, consider supporting those who need it most.
      </p>
      <p>
        Donations go <strong>directly to AID India</strong>, a non-profit
        supporting farmer families in crisis. VexTrainer receives nothing.
      </p>
      <a href="/Donate" class="btn-donate">🙏 Learn More &amp; Donate</a>
      <p class="donation-note">
        Secure donations via <strong>AidIndia.org</strong> ·
        Tax-deductible where applicable
      </p>
    </div>
  </section>

  @* ═══ FINAL CTA ══════════════════════════════════════════ *@
  <section class="final-cta">
    <h2>Ready to level up<br/>your team's code?</h2>
    <p>Free forever. No credit card. No catch. Just better code.</p>
    <a href="/Auth/Register" class="btn-glow btn-glow-primary">
      🚀 Create Free Account
    </a>
  </section>

</div>

@section Scripts {
<script>
// Animated counter for stats
(function() {
    function animateCounter(el) {
        var target = parseInt(el.getAttribute('data-target'), 10) || 0;
        if (target === 0) { el.textContent = '0'; return; }
        var duration = 1800;
        var start    = performance.now();
        function step(now) {
            var elapsed = now - start;
            var progress = Math.min(elapsed / duration, 1);
            // ease out cubic
            var eased = 1 - Math.pow(1 - progress, 3);
            var current = Math.floor(eased * target);
            el.textContent = target >= 1000
                ? current.toLocaleString()
                : current;
            if (progress < 1) requestAnimationFrame(step);
            else el.textContent = target >= 1000
                ? target.toLocaleString()
                : target;
        }
        requestAnimationFrame(step);
    }

    // Trigger on scroll into view
    var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
            if (entry.isIntersecting) {
                animateCounter(entry.target);
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.3 });

    document.querySelectorAll('.stat-number[data-target]').forEach(function(el) {
        observer.observe(el);
    });
})();
</script>
}
